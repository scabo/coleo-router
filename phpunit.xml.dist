<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    bootstrap="vendor/autoload.php"
    colors="true"
    testdox="true"
>
<php>
  <ini name="memory_limit" value="-1" />
  <ini name="display_errors" value="true" />
</php>
<testsuites>
  <testsuite name="all tests">
    <directory>tests</directory>
  </testsuite>
</testsuites>
</phpunit>